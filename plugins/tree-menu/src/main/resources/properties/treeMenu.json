[{
    "title" : "@@userview.treeMenu.config@@",
    "properties" : [{
        "name" : "id",
        "label" : "Id",
        "type" : "hidden"
    },
    {
        "name" : "customId",
        "label" : "@@userview.treeMenu.customId@@",
        "type" : "textfield",
        "regex_validation" : "^[a-zA-Z0-9_]+$",
        "validation_message" : "@@userview.treeMenu.invalidId@@"
    },
    {
        "name" : "label",
        "label" : "@@userview.treeMenu.label@@",
        "type" : "textfield",
        "required" : "True"
    },
    {
        "name" : "mode",
        "label" : "@@userview.treeMenu.mode@@",
        "type" : "selectbox",
        "value" : "legacy",
        "options" : [
            {"value" : "demo", "label" : "@@userview.treeMenu.mode.demo@@"},
            {"value" : "metamodel", "label" : "@@userview.treeMenu.mode.metamodel@@"},
            {"value" : "legacy", "label" : "@@userview.treeMenu.mode.legacy@@"}
        ]
    }]
},
{
    "title" : "@@userview.treeMenu.configuredConfig@@",
    "properties" : [{
        "name" : "configTableName",
        "label" : "@@userview.treeMenu.configured.configTable@@",
        "description" : "@@userview.treeMenu.configured.configTableDesc@@",
        "type" : "textfield",
        "value" : "tm_tree_config",
        "control_field" : "mode",
        "control_value" : "metamodel",
        "control_use_regex" : "false"
    }]
},
{
    "title" : "@@userview.treeMenu.appearance@@",
    "properties" : [{
        "name" : "treePanelWidth",
        "label" : "@@userview.treeMenu.appearance.treePanelWidth@@",
        "type" : "textfield",
        "value" : "300",
        "control_field" : "mode",
        "control_value" : "metamodel",
        "control_use_regex" : "false"
    },
    {
        "name" : "showSearch",
        "label" : "@@userview.treeMenu.appearance.showSearch@@",
        "type" : "checkbox",
        "value" : "true",
        "options" : [
            {"value" : "true", "label" : ""}
        ],
        "control_field" : "mode",
        "control_value" : "metamodel",
        "control_use_regex" : "false"
    },
    {
        "name" : "showBreadcrumb",
        "label" : "@@userview.treeMenu.appearance.showBreadcrumb@@",
        "type" : "checkbox",
        "value" : "true",
        "options" : [
            {"value" : "true", "label" : ""}
        ],
        "control_field" : "mode",
        "control_value" : "metamodel",
        "control_use_regex" : "false"
    },
    {
        "name" : "pageSize",
        "label" : "@@userview.treeMenu.appearance.pageSize@@",
        "type" : "textfield",
        "value" : "50",
        "control_field" : "mode",
        "control_value" : "metamodel",
        "control_use_regex" : "false"
    },
    {
        "name" : "defaultContentHtml",
        "label" : "@@userview.treeMenu.appearance.defaultContent@@",
        "type" : "codeeditor",
        "mode" : "html",
        "control_field" : "mode",
        "control_value" : "metamodel",
        "control_use_regex" : "false"
    }]
},
{
    "title" : "@@userview.treeMenu.legacyConfig@@",
    "properties" : [{
        "name" : "binder",
        "label" : "@@userview.treeMenu.legacy.binder@@",
        "type" : "elementselect",
        "options_ajax" : "[CONTEXT_PATH]/web/property/json/getElements?classname=org.joget.apps.datalist.model.DataListBinderDefault",
        "url" : "[CONTEXT_PATH]/web/property/json[APP_PATH]/getPropertyOptions",
        "control_field" : "mode",
        "control_value" : "legacy",
        "control_use_regex" : "false"
    },
    {
        "name" : "depth",
        "label" : "@@userview.treeMenu.depth@@",
        "type" : "textfield",
        "value" : "2",
        "control_field" : "mode",
        "control_value" : "legacy",
        "control_use_regex" : "false"
    }]
},
{
    "title" : "@@userview.treeMenu.mapping@@",
    "properties" : [{
        "name" : "treeNodeLabel",
