{
  "className": "org.joget.apps.form.model.Form",
  "properties": {
    "id": "qa_tab",
    "name": "QA Tab",
    "description": "Logical grouping of rules per service (e.g. 'Identity', 'Geography'). Used by the validation panel to render issue chips per tab and by status-transition gates to scope failures.",
    "tableName": "qa_tab",
    "loadBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    },
    "storeBinder": {
      "className": "org.joget.apps.form.lib.WorkflowFormBinder",
      "properties": {}
    },
    "permission": {
      "className": "",
      "properties": {}
    }
  },
  "elements": [
    {
      "className": "org.joget.apps.form.model.Section",
      "properties": {
        "id": "main",
        "label": "Tab"
      },
      "elements": [
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": {
            "width": "50%"
          },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "serviceId",
                "label": "Service ID (FK)",
                "size": "60",
                "maxlength": "60",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "mandatory": "true"
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "tabCode",
                "label": "Tab Code",
                "size": "40",
                "maxlength": "40",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "mandatory": "true",
                    "regex": "^[a-z0-9_]+$",
                    "regexMessage": "Lowercase + underscore only"
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "tabLabel",
                "label": "Tab Label (UI)",
                "size": "60",
                "maxlength": "100",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "mandatory": "true"
                  }
                }
              }
            }
          ]
        },
        {
          "className": "org.joget.apps.form.model.Column",
          "properties": {
            "width": "50%"
          },
          "elements": [
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "tabFormId",
                "label": "Tab Form ID",
                "size": "60",
                "maxlength": "60",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "mandatory": "true"
                  }
                }
              }
            },
            {
              "className": "org.joget.apps.form.lib.TextField",
              "properties": {
                "id": "tabOrder",
                "label": "Display Order",
                "size": "10",
                "maxlength": "10",
                "value": "100",
                "validator": {
                  "className": "org.joget.apps.form.lib.DefaultValidator",
                  "properties": {
                    "regex": "^[0-9]+$",
                    "regexMessage": "Integer only"
                  }
                }
              }
            }
          ]
        }
      ]
    }
  ]
}