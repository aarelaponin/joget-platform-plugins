digraph eco {
  graph [rankdir=TB, nodesep=0.5, ranksep=0.8, bgcolor="white", fontname="Helvetica"];
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=13, penwidth=1.4, margin="0.22,0.14", color="#263238"];
  edge [fontname="Helvetica", fontsize=11, color="#455A64", penwidth=1.6];

  subgraph cluster_in {
    label="  AUTHOR-TIME — how work is produced"; labeljust="l"; fontsize=14; fontname="Helvetica-Bold"; color="#90A4AE"; style="rounded"; bgcolor="#FAFAFA"; penwidth=1.3;
    skills [label=<<b>joget-claude-skills</b><br/><font point-size="11">the authoring method</font>>, fillcolor="#E3F2FD", color="#1565C0"];
    jkit   [label=<<b>joget-spec-kit · jkit</b><br/><font point-size="11">spec → artefacts engine</font>>, fillcolor="#E3F2FD", color="#1565C0"];
  }

  plat [label=<<b>joget-platform-plugins</b><br/><font point-size="11">the runtime-extension library&#160;·&#160;registry.yaml = single source of truth<br/>Foundation capabilities&#160;+&#160;Domain packs</font>>, fillcolor="#EDE7F6", color="#5E35B1", penwidth=2.3, fontsize=15];

  subgraph cluster_out {
    label="  RUN-TIME — consumed by any app"; labeljust="l"; fontsize=14; fontname="Helvetica-Bold"; color="#90A4AE"; style="rounded"; bgcolor="#FAFAFA"; penwidth=1.3;
    dmbb [label=<<b>DMBB</b><br/><font point-size="11">tax admin</font>>, fillcolor="#E8F5E9", color="#2E7D32"];
    frs  [label=<<b>FRS</b><br/><font point-size="11">registration</font>>, fillcolor="#E8F5E9", color="#2E7D32"];
    gam  [label=<<b>GAM</b><br/><font point-size="11">banking</font>>, fillcolor="#E8F5E9", color="#2E7D32"];
    next [label=<<b>…next app</b><br/><font point-size="11">any domain</font>>, fillcolor="#F5F5F5", color="#B0BEC5", style="rounded,filled,dashed"];
  }

  skills -> jkit [style=dashed, color="#B0BEC5"];
  jkit  -> plat [label="reads registry / config contract"];
  plat -> dmbb [style=invis]; plat -> frs [style=invis]; plat -> gam [style=invis]; plat -> next [style=invis];
  dmbb -> plat [label="depends on · pins version", constraint=false, color="#2E7D32"];
  frs  -> plat [constraint=false, color="#2E7D32"]; gam -> plat [constraint=false, color="#2E7D32"];
  next -> plat [constraint=false, style=dashed, color="#B0BEC5"];

  { rank=same; skills; jkit; }
  { rank=same; dmbb; frs; gam; next; }
}
