{
  "formId": "ppRefForm",
  "formName": "Platform Plugins Reference Form",
  "tableName": "pp_ref",
  "targetAppId": "platformRef",
  "targetAppVersion": "1",
  "createApiEndpoint": false,
  "createCrud": true,
  "formDefinition": {
    "className": "org.joget.apps.form.model.Form",
    "properties": {
      "id": "ppRefForm",
      "name": "Platform Plugins Reference Form",
      "tableName": "pp_ref",
      "loadBinder": {
        "className": "com.fiscaladmin.joget.formprefill.FormPrefillLoadBinder",
        "properties": {
          "enabled": "true",
          "onlyOnAdd": "true",
          "keySources": [{ "source": "requestParam", "name": "ref" }],
          "formId": "ppRefForm",
          "matchField": "id",
          "mappings": []
        }
      },
      "storeBinder": {
        "className": "org.joget.apps.form.lib.WorkflowFormBinder",
        "properties": {}
      }
    },
    "elements": [
      {
        "className": "org.joget.apps.form.model.Section",
        "properties": { "id": "s1", "label": "Reference" },
        "elements": [
          {
            "className": "org.joget.apps.form.model.Column",
            "properties": { "width": "100%" },
            "elements": [
              { "className": "org.joget.apps.form.lib.TextField",
                "properties": { "id": "firstName", "label": "First name" } },
              { "className": "org.joget.apps.form.lib.TextField",
                "properties": { "id": "lastName", "label": "Last name" } },
              { "className": "global.govstack.concatfield.element.ConcatFieldElement",
                "properties": { "id": "fullName", "label": "Full name (concat plugin)",
                  "sourceFields": "firstName;lastName", "separator": " ",
                  "skipEmpty": "true", "updateOn": "change" } },
              { "className": "global.govstack.lookupfield.element.LookupFieldElement",
                "properties": { "id": "lookupDemo", "label": "Lookup (lookup-field plugin)",
                  "sourceFieldId": "firstName", "lookupFormId": "ppRefForm",
                  "lookupColumn": "lastName", "lookupKeyColumn": "firstName", "updateOn": "change" } },
              { "className": "global.govstack.ruleeditor.element.RuleEditorElement",
                "properties": { "id": "ruleDemo", "label": "Rule editor (rule-editor + rules-api plugins)",
                  "scopeCode": "platformRef", "showDictionary": "true", "showSaveButton": "true" } },
              { "className": "global.govstack.formquality.element.QualityBannerElement",
                "properties": { "id": "qualityBanner", "label": "Quality banner (form-quality plugin)" } }
            ]
          }
        ]
      }
    ]
  }
}
